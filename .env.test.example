# Credentials for manual live testing.
# Copy this file to .env.test and fill in your values:
#   cp .env.test.example .env.test
#
# Then source it before running a live test script:
#   source .env.test
#   uv run python scripts/test_github_live.py
#   uv run python scripts/test_aws_live.py
#   uv run python scripts/test_google_workspace_live.py

# --- GitHub ---
export GITHUB_TEST_PAT="ghp_your_token_here"
export GITHUB_TEST_ORG="your-org-name"

# --- AWS ---
export AWS_TEST_ACCESS_KEY_ID="AKIA..."
export AWS_TEST_SECRET_ACCESS_KEY="your-secret-key"
export AWS_TEST_REGION="us-east-1"
# export AWS_TEST_SESSION_TOKEN=""  # Only for temporary credentials

# --- Google Workspace ---
export GOOGLE_TEST_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# Or use a file path: export GOOGLE_TEST_SERVICE_ACCOUNT_JSON=/path/to/key.json
export GOOGLE_TEST_DELEGATED_EMAIL="admin@your-domain.com"
